{
  "name": "@tsonic/nodejs",
  "version": "10.0.49-next.0",
  "description": "Native Tsonic implementation of Node.js APIs",
  "type": "module",
  "exports": {
    "./assert.js": "./src/assert-module.ts",
    "./buffer.js": "./src/buffer/index.ts",
    "./child_process.js": "./src/child_process/index.ts",
    "./console.js": "./src/console-module.ts",
    "./crypto.js": "./src/crypto/index.ts",
    "./dgram.js": "./src/dgram/index.ts",
    "./dns.js": "./src/dns/index.ts",
    ".": "./src/index.ts",
    "./events.js": "./src/events-module.ts",
    "./fs.js": "./src/fs-module.ts",
    "./http.js": "./src/http/index.ts",
    "./index.js": "./src/index.ts",
    "./os.js": "./src/os/index.ts",
    "./path.js": "./src/path-module.ts",
    "./perf_hooks.js": "./src/perf_hooks/index.ts",
    "./process.js": "./src/process-module.ts",
    "./querystring.js": "./src/querystring-module.ts",
    "./readline.js": "./src/readline/index.ts",
    "./stream.js": "./src/stream/index.ts",
    "./string_decoder.js": "./src/string_decoder/index.ts",
    "./timers.js": "./src/timers-module.ts",
    "./url.js": "./src/url/index.ts",
    "./net.js": "./src/net/index.ts",
    "./tls.js": "./src/tls/index.ts",
    "./util.js": "./src/util-module.ts",
    "./zlib.js": "./src/zlib/index.ts"
  },
  "files": [
    "src/**/*.ts",
    "tsonic/package-manifest.json",
    "README.md"
  ],
  "keywords": [
    "nodejs",
    "tsonic",
    "typescript",
    "source-package",
    "native"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tsoniclang/nodejs-next.git"
  },
  "dependencies": {
    "@tsonic/core": "10.0.40",
    "@tsonic/dotnet": "10.0.40",
    "@tsonic/js": "10.0.48"
